    {
      "parameters": {
        "jsCode": "const today = new Date().toISOString().split('T')[0];\nconst openRows = $input.all()\n  .map(item => item.json)\n  .filter(row => row['Run Date'] === today)\n  .filter(row => String(row['Status (OPEN / CLOSED / UNKNOWN)'] || '').toUpperCase() === 'OPEN')\n  .filter(row => String(row['Email Sent (Yes/No)'] || '').toUpperCase() !== 'YES');\n\nconst count = openRows.length;\nif (count === 0) {\n  return [{ json: { count: 0, html: '', rowsToMark: [] } }];\n}\n\nconst itemsHtml = openRows.map(row => {\n  const deadline = row['Deadline Detected'] || 'Confirm on official site';\n  const days = row['Days Until Deadline'] ? row['Days Until Deadline'] + ' days left' : 'Deadline unknown';\n  const eligibility = row['Eligibility Summary (AI)'] || 'See official site for details';\n  const url = row['Official URL'] || '#';\n  return `\n    <div style=\"border:1px solid #e5e7eb;border-radius:10px;padding:18px 20px;margin-bottom:16px;background:#ffffff;\">\n      <div style=\"font-size:18px;font-weight:700;color:#16213e;margin-bottom:6px;\">${row['Scholarship Name'] || 'Scholarship'}</div>\n      <div style=\"font-size:13px;color:#b45309;font-weight:700;margin-bottom:8px;\">${days} \u00b7 ${deadline}</div>\n      <div style=\"font-size:14px;line-height:1.6;color:#334155;margin-bottom:14px;\">${eligibility}</div>\n      <a href=\"${url}\" style=\"display:inline-block;background:#1a3a2a;color:#ffffff;text-decoration:none;padding:12px 18px;border-radius:8px;font-weight:700;\">Open Scholarship Page</a>\n    </div>`;\n}).join('');\n\nconst html = `<!DOCTYPE html><html><head><meta charset=\"utf-8\"><title>Scholarship Monitor Digest</title></head><body style=\"margin:0;padding:24px;background:#f3f4f6;font-family:Arial,sans-serif;color:#111827;\"><div style=\"max-width:760px;margin:0 auto;background:#ffffff;border-radius:14px;overflow:hidden;box-shadow:0 8px 30px rgba(0,0,0,.08);\"><div style=\"background:#1a3a2a;color:#ffffff;padding:28px 32px;\"><div style=\"font-size:12px;letter-spacing:1.2px;text-transform:uppercase;opacity:.8;margin-bottom:8px;\">Weekly Scholarship Monitor</div><div style=\"font-size:28px;font-weight:800;line-height:1.2;\">${count} open scholarship${count !== 1 ? 's' : ''} found</div><div style=\"font-size:14px;opacity:.85;margin-top:8px;\">Run date: ${today}</div></div><div style=\"padding:28px 32px;background:#f9fafb;\">${itemsHtml}</div></div></body></html>`;\n\nconst rowsToMark = openRows.map(row => ({\n  'Run Date': row['Run Date'] || '',\n  'Scholarship ID': row['Scholarship ID'] || '',\n  'Email Sent (Yes/No)': 'Yes'\n}));\n\nreturn [{ json: { count, html, rowsToMark } }];"
      },
