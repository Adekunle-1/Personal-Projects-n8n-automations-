    {
      "parameters": {
        "jsCode": "const scholarship = $('Split in Batches (1 per batch)').first().json || {};\nconst merged = $json || {};\n\nconst firecrawlContent =\n  merged?.data?.markdown ||\n  merged?.markdown ||\n  merged?.error?.message ||\n  merged?.errorDescription ||\n  merged?.errorMessage ||\n  'Firecrawl failed or returned no content';\n\nconst braveSnippets =\n  (merged?.web?.results || [])\n    .slice(0, 3)\n    .map(result => `${result.title}: ${result.description}`)\n    .join('\\n') ||\n  'No Brave results';\n\nreturn [\n  {\n    json: {\n      ...scholarship,\n      firecrawl_content: String(firecrawlContent).substring(0, 3000),\n      brave_snippets: String(braveSnippets).substring(0, 1500)\n    }\n  }\n];"
      },
      "id": "__NODE_3__",
      "name": "Merge Firecrawl + Brave Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1664,
        1456
      ]
    },
    {
      "parameters": {
        "jsCode": "const sch = $('Merge Firecrawl + Brave Data').first().json || {};\nconst raw = $json.content || $json.message?.content || $json.text || '{}';\n\nlet analysis = {};\ntry {\n  const cleaned = raw.replace(/```json|```/g, '').trim();\n  analysis = JSON.parse(cleaned);\n} catch (e) {\n  analysis = {\n    status: 'UNKNOWN',\n    deadline: '',\n    eligibility_summary: '',\n    required_documents: '',\n    action_checklist: [],\n    confidence: 'LOW',\n    raw_snippet: String(raw).substring(0, 200)\n  };\n}\n\nconst runDate = new Date().toISOString().split('T')[0];\n\nlet daysUntil = '';\nif (analysis.deadline) {\n  const deadlineDate = new Date(analysis.deadline);\n  const today = new Date();\n  const diff = Math.round((deadlineDate - today) / (1000 * 60 * 60 * 24));\n  daysUntil = isNaN(diff) ? '' : String(diff);\n}\n\nconst checklist = Array.isArray(analysis.action_checklist)\n  ? analysis.action_checklist.join(' | ')\n  : (analysis.action_checklist || '');\n\nreturn [\n  {\n    json: {\n      'Run Date': runDate,\n      'Scholarship ID': sch['ID'] || '',\n      'Scholarship Name': sch['Scholarship Name'] || '',\n      'Official URL': sch['Official URL'] || '',\n      'Status (OPEN / CLOSED / UNKNOWN)': analysis.status || 'UNKNOWN',\n      'Deadline Detected': analysis.deadline || '',\n      'Days Until Deadline': daysUntil,\n      'Eligibility Summary (AI)': analysis.eligibility_summary || '',\n      'Required Documents (AI)': analysis.required_documents || ''\n    }\n  }\n];"
      },
